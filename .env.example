WOO_KEY=ck_xxxxxxxxxxxxxxxxxxxx
WOO_SECRET=cs_xxxxxxxxxxxxxxxxxxxx

# ── Scheduler ─────────────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=60
