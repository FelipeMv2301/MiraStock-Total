# ── Integraciones-BQ (requerido — fuente de datos SAP) ────────────────────────
# Endpoint consumido: GET /api/v1/stock/catalog
API_PLANILLAS_URL=http://localhost:8000
# API Key para X-API-Key header (dejar vacío si el servidor no requiere autenticación)
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_PLANILLAS_KEY=

# ── WooCommerce (opcional — imágenes, categorías, precios y descuentos) ────────
WOO_URL=https://bioquimica.cl
WOO_KEY=ck_xxxxxxxxxxxxxxxxxxxx
WOO_SECRET=cs_xxxxxxxxxxxxxxxxxxxx

# ── Autenticación Google OAuth ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
# Base URL pública de la app (usado para el redirect_uri de Google)
# Ejemplo producción: APP_BASE_URL=https://mirastock.bioquimica.cl
APP_BASE_URL=http://localhost:8001

# ── Sesión ─────────────────────────────────────────────────────────────────────
# Genera un string aleatorio largo y seguro
SESSION_SECRET=cambia-esto-por-un-secreto-seguro

# ── Scheduler ─────────────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=60

# ── Google Drive (scripts/export_images_to_drive.py) ──────────────────────────
# Service Account JSON codificado en base64: base64 -w0 service-account.json
GDRIVE_CREDENTIALS_JSON_B64=ewogICJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsCi...
# ID de la carpeta Drive destino (se genera automáticamente si está vacío)
GDRIVE_FOLDER_ID=
# Nombre de la carpeta a crear si GDRIVE_FOLDER_ID está vacío
GDRIVE_FOLDER_NAME=MiraStock Imágenes
